{
  "extends": "@adonisjs/tsconfig/tsconfig.app.json",
  "compilerOptions": {
    "rootDir": "./",
    "jsx": "react",
    "outDir": "./build",
    "paths": {
      "#controllers/*": ["./app/controllers/*.js"],
      "#exceptions/*": ["./app/exceptions/*.js"],
      "#models/*": ["./app/models/*.js"],
      "#mails/*": ["./app/mails/*.js"],
      "#services/*": ["./app/services/*.js"],
      "#listeners/*": ["./app/listeners/*.js"],
      "#events/*": ["./app/events/*.js"],
      "#generated/*": ["./.adonisjs/server/*.js"],
      "#middleware/*": ["./app/middleware/*.js"],
      "#transformers/*": ["./app/transformers/*.js"],
      "#validators/*": ["./app/validators/*.js"],
      "#providers/*": ["./providers/*.js"],
      "#policies/*": ["./app/policies/*.js"],
      "#abilities/*": ["./app/abilities/*.js"],
      "#repositories/*": ["./app/repositories/*.js"],
      "#database/*": ["./database/*.js"],
      "#tests/*": ["./tests/*.js"],
      "#start/*": ["./start/*.js"],
      "#config/*": ["./config/*.js"],
      "#orgbuilder/controllers/*": ["./app/orgbuilder/controllers/*.js"],
      "#orgbuilder/services/*": ["./app/orgbuilder/services/*.js"],
      "#orgbuilder/repositories/*": ["./app/orgbuilder/repositories/*.js"],
      "#orgbuilder/validators/*": ["./app/orgbuilder/validators/*.js"],
      "#hrms/controllers/*": ["./app/hrms/controllers/*.js"],
      "#hrms/services/*": ["./app/hrms/services/*.js"],
      "#hrms/repositories/*": ["./app/hrms/repositories/*.js"],
      "#hrms/validators/*": ["./app/hrms/validators/*.js"]
    }
  },
  "references": [{ "path": "./tsconfig.inertia.json" }]
}
